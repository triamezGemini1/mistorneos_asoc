# =============================================================================
# Mistorneos - Variables de entorno
# Copiar a .env y ajustar valores. En producción no subas .env al repositorio.
# =============================================================================

# Entorno: development | production (auto-detecta por host si no se define)
APP_ENV=development

# URL base de la aplicación (opcional)
# - Si no se define: en localhost se usa automáticamente http://localhost/mistorneos
# - En producción: https://tudominio.com/mistorneos
# - Entorno de pruebas (subpath): https://laestaciondeldominohoy.com/pruebas
# APP_URL=

# Debug (solo desarrollo)
APP_DEBUG=false

# -----------------------------------------------------------------------------
# Base de datos principal (mistorneos)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mistorneos
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# -----------------------------------------------------------------------------
# Base de datos secundaria (personas / fvdadmin) - opcional
# -----------------------------------------------------------------------------
# DB_SECONDARY_HOST=localhost
# DB_SECONDARY_PORT=3306
# DB_SECONDARY_DATABASE=personas
# DB_SECONDARY_USERNAME=root
# DB_SECONDARY_PASSWORD=

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
# Nombre de la cookie de sesión
SESSION_NAME=mistorneos_session

# Duraci?n de sesi?n (evita "sesi?n expirada" con el panel abierto o importaci?n masiva).
# SESSION_GC_MAXLIFETIME=28800   # segundos que el servidor conserva la sesi?n (ej. 8 h)
# SESSION_COOKIE_LIFETIME=28800 # vida de la cookie en el navegador (segundos)
# SESSION_LIFETIME=240          # opcional: minutos (si no define SESSION_GC_MAXLIFETIME, se usa max(esto?60, ...))

# Dominio de la cookie de sesion (opcional). Si entran por www y sin www, use el punto inicial:
# SESSION_COOKIE_DOMAIN=.laestaciondeldominohoy.com
# Regenerar ID de sesion cada N segundos (anti session fixation). Por defecto ~ max(1h, SESSION_GC).
# Poner 0 para desactivar la regeneracion periodica (recomendado si fallan fetch/API tras estar logueados).
# SESSION_REGENERATE_AFTER_SECONDS=0

# Debug de sesión: escribe [SESSION_DEBUG] en error_log en cada paso (login, index, profile, etc.).
# Poner SESSION_DEBUG=1 para diagnosticar pérdida de sesión. En session_start_early solo aplica si está en el servidor (SetEnv).
# SESSION_DEBUG=0

# Clave CSRF (generar una aleatoria de 32+ caracteres en producción)
CSRF_KEY=replace_with_random_32_chars

# -----------------------------------------------------------------------------
# Producción (opcional)
# -----------------------------------------------------------------------------
# Forzar redirección HTTPS en producción (true|false)
# FORCE_HTTPS=true
